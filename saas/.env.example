# ADC SaaS local development environment
# Copy to saas/.env before running the canonical local stack.

# Application
APP_ENV=local
APP_NAME=ADC Trading Platform

# Backend runtime
DATABASE_URL=postgresql://adc:adc@localhost:5432/adc
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Frontend runtime (Vite)
VITE_API_URL=http://localhost:8000/api/v1

# Provider adapters for MVP-safe local runs
MARKET_DATA_PROVIDER=mock
BROKER_PROVIDER=mock
AI_PROVIDER=mock

# Backend optional settings
API_HOST=0.0.0.0
API_PORT=8000
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT=30
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@adctrading.com

# Billing / integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
