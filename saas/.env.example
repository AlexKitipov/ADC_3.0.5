# ADC SaaS MVP environment contract
# Copy to saas/.env for local Docker Compose runs.
# Hosted deployments should set the same keys in the provider dashboard.

# -----------------------------------------------------------------------------
# Required for MVP backend runtime
# -----------------------------------------------------------------------------
APP_ENV=local
APP_NAME=ADC Trading Platform
SECRET_KEY=change-me
DATABASE_URL=postgresql://adc:adc@localhost:5432/adc
# Include every deployed frontend origin that may call the API.
# Example: CORS_ORIGINS=["https://adc-web.vercel.app","http://localhost:5173"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Local Compose Postgres bootstrap values. Managed Postgres providers usually
# expose DATABASE_URL directly, so these are only required for the local stack.
POSTGRES_USER=adc
POSTGRES_PASSWORD=adc
POSTGRES_DB=adc

# -----------------------------------------------------------------------------
# Required for MVP frontend build/runtime
# -----------------------------------------------------------------------------
# Local development target:
VITE_API_URL=http://localhost:8000/api/v1
# Hosted frontend build target example:
# VITE_API_URL=https://<backend-domain>/api/v1

# -----------------------------------------------------------------------------
# Safe MVP provider defaults
# -----------------------------------------------------------------------------
# yahoo is the default no-budget daily market-data provider; use mock for
# offline demos/tests. Broker and AI providers stay mocked for MVP deploys.
MARKET_DATA_PROVIDER=yahoo
BROKER_PROVIDER=mock
AI_PROVIDER=mock

# -----------------------------------------------------------------------------
# Optional backend settings
# -----------------------------------------------------------------------------
# Local Python/Compose commands use API_PORT. Render/Railway inject PORT and the
# deploy start command should pass --port $PORT without changing local commands.
API_HOST=0.0.0.0
API_PORT=8000
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALPHA_VANTAGE_API_KEY=

# Redis/Celery are optional for the cheap MVP request path. Leave REDIS_URL unset
# on the cheapest hosted API unless background workers are enabled.
REDIS_URL=redis://localhost:6379/0

# Optional notification email settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT=30
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@adctrading.com

# Optional billing / third-party integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
