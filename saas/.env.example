# Application
APP_ENV=local
APP_NAME=ADC Trading Platform

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql://adc:adc@localhost:5432/adc
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email
